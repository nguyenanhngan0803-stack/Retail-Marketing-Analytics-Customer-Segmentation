@model List<BasketRule>
@{
    ViewData["Title"] = "Giỏ hàng";
}

<h2 class="mb-4">Top luật mua kèm</h2>

<div class="card shadow-sm border-0">
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="text-muted">Chưa có file giao dịch hoặc không đủ dữ liệu để tạo luật mua kèm.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Nếu mua</th>
                            <th>Thì hay mua kèm</th>
                            <th>Support</th>
                            <th>Confidence</th>
                            <th>Lift</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var rule in Model)
                    {
                        <tr>
                            <td>@rule.Antecedent</td>
                            <td>@rule.Consequent</td>
                            <td>@rule.Support.ToString("N4")</td>
                            <td>@rule.Confidence.ToString("N4")</td>
                            <td>@rule.Lift.ToString("N4")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
